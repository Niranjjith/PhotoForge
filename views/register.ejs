<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register - GraphyHub</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <style>
    .register-bg { background: linear-gradient(135deg, #14b8a6 0%, #06b6d4 50%, #0ea5e9 100%); }
  </style>
</head>
<body class="bg-gradient-to-br from-red-50/50 via-white to-stone-50 min-h-screen flex items-center justify-center py-12">
  <div class="bg-white shadow-2xl rounded-2xl flex flex-col md:flex-row overflow-hidden w-11/12 max-w-4xl">
    <!-- Left side (image) -->
    <div class="md:w-1/2 bg-cover bg-center min-h-64 md:min-h-0" style="background-image: url('https://images.unsplash.com/photo-1542038784456-1ea8e935640e?auto=format&fit=crop&w=1500&q=85');"></div>

    <!-- Right side (form) -->
    <div class="md:w-1/2 p-10 flex flex-col justify-center">
      <h2 class="text-4xl font-bold mb-2 text-red-700 text-center">Create Your Account</h2>
      <p class="text-gray-600 text-center mb-8">Join GraphyHub to view portfolios as a client or add your own as a photographer / video editor</p>

      <% if (typeof error !== 'undefined' && error.length > 0) { %>
        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 px-4 py-3 rounded mb-4">
          <%= error[0] %>
        </div>
      <% } %>
      <% if (typeof success !== 'undefined' && success.length > 0) { %>
        <div class="bg-green-50 border-l-4 border-green-500 text-green-700 px-4 py-3 rounded mb-4">
          <%= success[0] %>
        </div>
      <% } %>

      <form action="/auth/register" method="POST" class="space-y-5">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
          <input type="text" id="name" name="name" placeholder="John Doe" required class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-red-500 focus:outline-none">
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-red-500 focus:outline-none">
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-red-500 focus:outline-none">
        </div>
        <div>
          <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Account Type</label>
          <select name="role" id="role" class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-red-500 focus:outline-none">
            <option value="customer">Client (Free) — View portfolios & book creators</option>
            <option value="provider">Photographer / Video Editor (Registration fee)</option>
          </select>
          <p class="text-xs text-gray-500 mt-1" id="provider-note" style="display: none;">
            <i class="fas fa-info-circle mr-1"></i>Creator registration requires a one-time payment of ₹10
          </p>
        </div>

        <button type="submit" class="w-full bg-red-700 text-white font-semibold py-3 rounded-lg hover:bg-red-800 transition">Register</button>
      </form>

      <p class="text-center text-gray-600 mt-6 text-sm">Already have an account?
        <a href="/auth/login" class="text-red-700 font-semibold hover:underline">Login here</a>
      </p>
      <p class="text-center mt-4">
        <a href="/" class="text-sm text-gray-500 hover:text-red-700"><i class="fas fa-arrow-left mr-1"></i>Back to Home</a>
      </p>
    </div>
  </div>

  <script>
    const role = document.getElementById('role');
    const providerNote = document.getElementById('provider-note');
    if (role && providerNote) {
      role.addEventListener('change', function() {
        providerNote.style.display = this.value === 'provider' ? 'block' : 'none';
      });
      providerNote.style.display = role.value === 'provider' ? 'block' : 'none';
    }
    gsap.from('.bg-white', { y: 30, opacity: 0, duration: 0.8, ease: 'power3.out' });
  </script>
</body>
</html>
