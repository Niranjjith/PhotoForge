<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Client Dashboard - GraphyHub</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <style>
    .dashboard-sidebar { min-height: calc(100vh - 80px); }
    .sidebar-item { transition: all 0.3s ease; }
    .sidebar-item.active { background: linear-gradient(135deg, rgba(6, 182, 212, 0.15), rgba(20, 184, 166, 0.15)); border-left: 4px solid #14b8a6; }
    .sidebar-item:hover { background: rgba(6, 182, 212, 0.08); transform: translateX(4px); }
    .content-section { display: none; animation: fadeInUp 0.5s ease-out; }
    .content-section.active { display: block; }
    .stat-card-icon { width: 60px; height: 60px; border-radius: 16px; display: flex; align-items: center; justify-content: center; }
    .glass-card { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(6, 182, 212, 0.2); }
    .floating-shape { position: absolute; border-radius: 50%; filter: blur(60px); opacity: 0.1; animation: float 8s ease-in-out infinite; }
    .provider-card { transition: all 0.3s ease; }
    .provider-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(6, 182, 212, 0.2); }
  </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-50 via-cyan-50/30 to-teal-50/30 relative overflow-hidden">
  <!-- Floating Background Shapes -->
  <div class="floating-shape w-96 h-96 bg-cyan-400 top-0 right-0"></div>
  <div class="floating-shape w-80 h-80 bg-teal-400 bottom-0 left-0" style="animation-delay: 2s;"></div>
  <div class="floating-shape w-72 h-72 bg-blue-400 top-1/2 right-1/4" style="animation-delay: 4s;"></div>

  <!-- Top Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 dashboard-glass border-b border-cyan-200/30 shadow-sm">
    <div class="max-w-full mx-auto px-6 py-4 flex justify-between items-center">
      <div class="flex items-center space-x-4">
        <a href="/" class="text-2xl font-bold gradient-text flex items-center gap-2">
          <i class="fas fa-camera-retro text-cyan-500"></i> GraphyHub
        </a>
        <span class="text-sm text-gray-500 hidden md:block">Client Portal</span>
      </div>
      <div class="flex items-center space-x-4">
        <a href="/providers" class="text-gray-700 hover:text-teal-600 transition flex items-center gap-2">
          <i class="fas fa-search"></i> <span class="hidden md:inline">Find Creators</span>
        </a>
        <form action="/auth/logout" method="POST" class="inline">
          <button class="btn-primary px-5 py-2 rounded-xl shadow-md transition text-sm">
            <i class="fas fa-sign-out-alt mr-1"></i> Logout
          </button>
        </form>
      </div>
    </div>
  </nav>

  <div class="flex pt-20 relative z-10">
    <!-- Sidebar Navigation -->
    <aside class="dashboard-sidebar w-64 bg-white/60 backdrop-blur-xl border-r border-cyan-200/30 shadow-lg fixed left-0 top-20 bottom-0 overflow-y-auto">
      <div class="p-6">
        <!-- User Profile Summary -->
        <div class="mb-8 p-4 rounded-2xl gradient-bg text-white shadow-lg">
          <div class="flex items-center space-x-3 mb-3">
            <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center border-2 border-white/50">
              <i class="fas fa-user text-xl"></i>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-bold text-sm truncate"><%= user.name %></h3>
              <p class="text-xs text-cyan-100">Client Account</p>
            </div>
          </div>
          <% if (user.isStudent) { %>
            <div class="flex items-center text-xs bg-white/20 px-2 py-1 rounded">
              <i class="fas fa-graduation-cap mr-1"></i>
              <span>Student Discount Active</span>
            </div>
          <% } %>
        </div>

        <!-- Navigation Menu -->
        <nav class="space-y-2">
          <button onclick="showSection('overview')" class="sidebar-item active w-full text-left px-4 py-3 rounded-xl flex items-center space-x-3">
            <i class="fas fa-chart-pie text-teal-600 w-5"></i>
            <span class="font-medium text-gray-700">Overview</span>
          </button>
          <button onclick="showSection('browse')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl flex items-center space-x-3">
            <i class="fas fa-search text-teal-600 w-5"></i>
            <span class="font-medium text-gray-700">Browse Creators</span>
          </button>
          <button onclick="showSection('bookings')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl flex items-center space-x-3">
            <i class="fas fa-calendar-check text-teal-600 w-5"></i>
            <span class="font-medium text-gray-700">My Bookings</span>
          </button>
          <button onclick="showSection('favorites')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl flex items-center space-x-3">
            <i class="fas fa-heart text-teal-600 w-5"></i>
            <span class="font-medium text-gray-700">Favorites</span>
          </button>
          <button onclick="showSection('reviews')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl flex items-center space-x-3">
            <i class="fas fa-star text-teal-600 w-5"></i>
            <span class="font-medium text-gray-700">My Reviews</span>
          </button>
        </nav>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 ml-64 p-8">
      <!-- Overview Section -->
      <div id="section-overview" class="content-section active">
        <div class="mb-8">
          <h1 class="text-4xl font-extrabold gradient-text mb-2">Welcome back, <%= user.name %>!</h1>
          <p class="text-gray-600">Here's your activity summary</p>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <div class="stat-card glass-card rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-cyan-400/20 to-transparent rounded-bl-full"></div>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-4">
                <div class="stat-card-icon gradient-bg text-white shadow-lg">
                  <i class="fas fa-calendar-check text-2xl"></i>
                </div>
              </div>
              <p class="text-gray-600 text-sm mb-1">My Bookings</p>
              <p class="text-4xl font-bold text-gray-800"><%= bookings ? bookings.length : 0 %></p>
              <p class="text-xs text-gray-500 mt-2">Active & upcoming</p>
            </div>
          </div>

          <div class="stat-card glass-card rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-pink-400/20 to-transparent rounded-bl-full"></div>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-4">
                <div class="stat-card-icon bg-gradient-to-br from-pink-500 to-rose-500 text-white shadow-lg">
                  <i class="fas fa-heart text-2xl"></i>
                </div>
              </div>
              <p class="text-gray-600 text-sm mb-1">Favorites</p>
              <p class="text-4xl font-bold text-gray-800" id="favorites-count">0</p>
              <p class="text-xs text-gray-500 mt-2">Saved creators</p>
            </div>
          </div>

          <div class="stat-card glass-card rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-teal-400/20 to-transparent rounded-bl-full"></div>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-4">
                <div class="stat-card-icon bg-gradient-to-br from-teal-500 to-emerald-500 text-white shadow-lg">
                  <i class="fas fa-star text-2xl"></i>
                </div>
              </div>
              <p class="text-gray-600 text-sm mb-1">Reviews Given</p>
              <p class="text-4xl font-bold text-gray-800"><%= reviewsGiven || 0 %></p>
              <p class="text-xs text-gray-500 mt-2">Your feedback</p>
            </div>
          </div>

          <div class="stat-card glass-card rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-emerald-400/20 to-transparent rounded-bl-full"></div>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-4">
                <div class="stat-card-icon bg-gradient-to-br from-emerald-500 to-green-500 text-white shadow-lg">
                  <i class="fas fa-rupee-sign text-2xl"></i>
                </div>
              </div>
              <p class="text-gray-600 text-sm mb-1">Total Spent</p>
              <p class="text-4xl font-bold text-gray-800">₹<%= totalSpent || 0 %></p>
              <p class="text-xs text-gray-500 mt-2">All time</p>
            </div>
          </div>
        </div>

        <!-- Quick Actions & Recent Activity -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Quick Actions -->
          <div class="glass-card rounded-2xl p-6 shadow-lg">
            <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
              <i class="fas fa-bolt text-teal-500 mr-2"></i> Quick Actions
            </h3>
            <div class="grid grid-cols-2 gap-3">
              <button onclick="showSection('browse')" class="p-4 bg-gradient-to-br from-cyan-50 to-teal-50 rounded-xl hover:shadow-md transition text-left border border-cyan-100">
                <i class="fas fa-search text-teal-600 text-xl mb-2"></i>
                <p class="font-semibold text-sm text-gray-800">Find Creators</p>
              </button>
              <button onclick="showSection('bookings')" class="p-4 bg-gradient-to-br from-blue-50 to-cyan-50 rounded-xl hover:shadow-md transition text-left border border-blue-100">
                <i class="fas fa-calendar-check text-blue-600 text-xl mb-2"></i>
                <p class="font-semibold text-sm text-gray-800">View Bookings</p>
              </button>
              <button onclick="showSection('favorites')" class="p-4 bg-gradient-to-br from-pink-50 to-rose-50 rounded-xl hover:shadow-md transition text-left border border-pink-100">
                <i class="fas fa-heart text-pink-600 text-xl mb-2"></i>
                <p class="font-semibold text-sm text-gray-800">My Favorites</p>
              </button>
              <a href="/providers" class="p-4 bg-gradient-to-br from-purple-50 to-pink-50 rounded-xl hover:shadow-md transition text-left border border-purple-100">
                <i class="fas fa-external-link-alt text-purple-600 text-xl mb-2"></i>
                <p class="font-semibold text-sm text-gray-800">Browse All</p>
              </a>
            </div>
          </div>

          <!-- Recent Bookings -->
          <div class="glass-card rounded-2xl p-6 shadow-lg">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-800 flex items-center">
                <i class="fas fa-clock text-teal-500 mr-2"></i> Recent Bookings
              </h3>
              <a href="/bookings/my-bookings" class="text-sm text-teal-600 hover:underline">View All</a>
            </div>
            <div class="space-y-3 max-h-64 overflow-y-auto">
              <% if (bookings && bookings.length > 0) { %>
                <% bookings.slice(0, 5).forEach(booking => { %>
                  <div class="flex items-center justify-between p-3 bg-white/50 rounded-xl border border-gray-100 hover:shadow-md transition">
                    <div class="flex items-center space-x-3">
                      <div class="w-10 h-10 rounded-full gradient-bg flex items-center justify-center text-white font-bold text-sm">
                        <%= booking.provider.businessName.charAt(0).toUpperCase() %>
                      </div>
                      <div>
                        <p class="font-semibold text-sm text-gray-800"><%= booking.provider.businessName %></p>
                        <p class="text-xs text-gray-500"><%= new Date(booking.eventDate).toLocaleDateString() %></p>
                      </div>
                    </div>
                    <div class="text-right">
                      <span class="text-xs px-2 py-1 rounded <%= booking.status === 'Accepted' ? 'bg-green-100 text-green-700' : booking.status === 'Pending' ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-700' %>">
                        <%= booking.status %>
                      </span>
                      <p class="text-xs text-gray-600 mt-1">₹<%= booking.finalAmount %></p>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <p class="text-gray-500 text-sm text-center py-8">No bookings yet</p>
              <% } %>
            </div>
          </div>
    </div>
        </div>
      </div>

      <!-- Browse Creators Section -->
      <div id="section-browse" class="content-section">
        <div class="mb-8">
          <h1 class="text-4xl font-extrabold gradient-text mb-2">Browse Creators</h1>
          <p class="text-gray-600">Discover photographers and video editors</p>
        </div>

        <div class="glass-card rounded-2xl p-6 shadow-lg mb-6">
          <form method="GET" action="/providers" class="flex gap-4">
            <input type="text" name="search" placeholder="Search creators..." 
              class="flex-1 p-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-400 focus:border-teal-400 focus:outline-none transition">
            <input type="text" name="city" placeholder="City" 
              class="p-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-400 focus:border-teal-400 focus:outline-none transition">
            <button type="submit" class="btn-primary px-6 py-3 rounded-xl shadow-md">
              <i class="fas fa-search mr-2"></i>Search
            </button>
          </form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% if (providers && providers.length > 0) { %>
            <% providers.forEach(provider => { %>
              <div class="provider-card glass-card rounded-2xl overflow-hidden shadow-lg">
                <div class="relative h-48 overflow-hidden">
                  <img src="<%= provider.coverImage || 'https://images.unsplash.com/photo-1452587925148-ce544e77e70d?auto=format&fit=crop&w=800&q=80' %>" 
                       alt="<%= provider.businessName %>" 
                       class="w-full h-full object-cover transform hover:scale-110 transition duration-500">
                  <% if (provider.isVerified) { %>
                    <div class="absolute top-4 right-4 bg-emerald-500 text-white px-3 py-1 rounded-full text-xs font-bold shadow-lg">
                      <i class="fas fa-check-circle mr-1"></i> Verified
                    </div>
                  <% } %>
                  <button onclick="toggleFavorite('<%= provider._id %>')" 
                    class="absolute top-4 left-4 bg-white/90 backdrop-blur p-2 rounded-full hover:bg-red-50 transition shadow-md">
                    <i class="fas fa-heart text-gray-400 favorite-icon" id="fav-<%= provider._id %>"></i>
                  </button>
                  <div class="absolute bottom-4 left-4 flex items-center bg-slate-900/70 backdrop-blur text-white px-3 py-2 rounded-lg">
                    <span class="star-rating mr-2">
                      <% for(let i = 0; i < 5; i++) { %>
                        <i class="fas fa-star text-xs <%= i < Math.round(provider.rating) ? 'text-cyan-300' : 'text-gray-400' %>"></i>
                  <button onclick="toggleFavorite('<%= provider._id %>')" 
                    class="absolute top-4 left-4 bg-white p-2 rounded-full hover:bg-red-50 transition">
                    <i class="fas fa-heart text-gray-400 favorite-icon" id="fav-<%= provider._id %>"></i>
                  </button>
                      <% } %>
                    </span>
                    <span class="font-bold"><%= provider.rating.toFixed(1) %></span>
                  </div>
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold mb-2 text-gray-800"><%= provider.businessName %></h3>
                  <p class="text-slate-600 mb-3 flex items-center text-sm">
                    <i class="fas fa-map-marker-alt text-teal-500 mr-2"></i>
                    <%= provider.city || provider.address || 'Location not specified' %>
                  </p>
                  <p class="text-gray-700 mb-4 line-clamp-2 text-sm"><%= provider.description || 'Photography & video' %></p>
                  <div class="flex items-center justify-between">
                    <a href="/providers/<%= provider._id %>" class="text-teal-600 font-semibold hover:text-cyan-600 transition text-sm">
                      View Portfolio <i class="fas fa-arrow-right ml-1"></i>
                    </a>
                    <span class="text-xs text-gray-500">
                      <i class="fas fa-users mr-1"></i><%= provider.totalReviews || 0 %>
                    </span>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="col-span-full text-center py-16 glass-card rounded-2xl">
              <i class="fas fa-camera text-6xl text-gray-300 mb-4"></i>
              <p class="text-xl text-gray-500 mb-4">No creators found.</p>
              <a href="/providers" class="text-teal-600 font-bold hover:underline">Browse All Creators</a>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Bookings Section -->
      <div id="section-bookings" class="content-section">
        <div class="mb-8 flex items-center justify-between">
          <div>
            <h1 class="text-4xl font-extrabold gradient-text mb-2">My Bookings</h1>
            <p class="text-gray-600">Track your project bookings</p>
          </div>
          <a href="/bookings/my-bookings" class="btn-primary px-6 py-3 rounded-xl shadow-md">
            <i class="fas fa-external-link-alt mr-2"></i>View All
          </a>
        </div>

        <div class="glass-card rounded-2xl p-8 shadow-lg">
          <div class="space-y-4">
            <% if (bookings && bookings.length > 0) { %>
              <% bookings.slice(0, 10).forEach(booking => { %>
                <div class="p-6 bg-white/60 rounded-xl border-2 border-gray-100 hover:border-teal-300 hover:shadow-lg transition">
                  <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-4">
                      <div class="w-12 h-12 rounded-full gradient-bg flex items-center justify-center text-white font-bold">
                        <%= booking.provider.businessName.charAt(0).toUpperCase() %>
                      </div>
                      <div>
                        <h4 class="font-bold text-gray-800"><%= booking.provider.businessName %></h4>
                        <p class="text-sm text-gray-500"><%= new Date(booking.eventDate).toLocaleDateString() %> at <%= booking.eventTime || 'TBD' %></p>
                      </div>
                    </div>
                    <span class="px-4 py-2 rounded-full text-sm font-semibold <%= booking.status === 'Accepted' ? 'bg-green-100 text-green-700' : booking.status === 'Pending' ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-700' %>">
                      <%= booking.status %>
                    </span>
                  </div>
                  <div class="grid md:grid-cols-3 gap-4 text-sm mb-4">
                    <div>
                      <p class="text-gray-500">Project Type</p>
                      <p class="font-semibold text-gray-800"><%= booking.eventType %></p>
                    </div>
                    <div>
                      <p class="text-gray-500">Guests</p>
                      <p class="font-semibold text-gray-800"><%= booking.guests %></p>
                    </div>
                    <div>
                      <p class="text-gray-500">Amount</p>
                      <p class="font-semibold text-teal-600 text-lg">₹<%= booking.finalAmount %></p>
                    </div>
                  </div>
                  <div class="flex gap-3">
                    <a href="/providers/<%= booking.provider._id %>" class="btn-primary px-4 py-2 rounded-xl text-sm shadow-md">
                      View Creator
                    </a>
                    <% if (booking.status === 'Completed') { %>
                      <a href="/providers/<%= booking.provider._id %>" class="px-4 py-2 bg-blue-500 text-white rounded-xl hover:bg-blue-600 transition text-sm font-semibold">
                        Write Review
                      </a>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="text-center py-16">
                <i class="fas fa-calendar-times text-6xl text-gray-300 mb-4"></i>
                <p class="text-gray-500 text-lg mb-2">No bookings yet</p>
                <a href="/providers" class="text-teal-600 hover:underline">Browse creators to get started</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Favorites Section -->
      <div id="section-favorites" class="content-section">
        <div class="mb-8">
          <h1 class="text-4xl font-extrabold gradient-text mb-2">Favorite Creators</h1>
          <p class="text-gray-600">Your saved photographers and video editors</p>
        </div>

        <div class="glass-card rounded-2xl p-8 shadow-lg">
          <div id="favorites-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="col-span-full text-center py-16">
              <i class="fas fa-heart text-6xl text-gray-300 mb-4"></i>
              <p class="text-gray-500 text-lg mb-2">No favorites yet</p>
              <p class="text-gray-400 text-sm">Start adding creators to your favorites!</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Reviews Section -->
      <div id="section-reviews" class="content-section">
        <div class="mb-8">
          <h1 class="text-4xl font-extrabold gradient-text mb-2">My Reviews</h1>
          <p class="text-gray-600">Reviews you've written for creators</p>
        </div>

        <div class="glass-card rounded-2xl p-8 shadow-lg">
          <div class="space-y-4">
            <% if (myReviews && myReviews.length > 0) { %>
              <% myReviews.forEach(review => { %>
                <div class="p-6 bg-white/60 rounded-xl border-2 border-gray-100 hover:border-teal-300 transition">
                  <div class="flex items-center justify-between mb-4">
                    <div>
                      <h3 class="text-xl font-bold text-gray-800"><%= review.provider.businessName %></h3>
                      <div class="star-rating mt-1">
                        <% for(let i = 0; i < 5; i++) { %>
                          <i class="fas fa-star <%= i < review.rating ? 'text-teal-500' : 'text-gray-300' %>"></i>
                        <% } %>
                      </div>
                    </div>
                    <span class="text-sm text-gray-500"><%= new Date(review.createdAt).toLocaleDateString() %></span>
                  </div>
                  <p class="text-gray-700 mb-3"><%= review.comment || 'No comment provided.' %></p>
                  <a href="/providers/<%= review.provider._id %>" class="text-teal-600 hover:text-cyan-600 text-sm font-semibold">
                    View Creator <i class="fas fa-arrow-right ml-1"></i>
                  </a>
                </div>
              <% }) %>
            <% } else { %>
              <div class="text-center py-16">
                <i class="fas fa-star text-6xl text-gray-300 mb-4"></i>
                <p class="text-gray-500 text-lg">You haven't written any reviews yet.</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    // Section switching
    function showSection(sectionName) {
      document.querySelectorAll('.content-section').forEach(section => section.classList.remove('active'));
      document.querySelectorAll('.sidebar-item').forEach(item => {
        item.classList.remove('active');
        item.classList.add('text-gray-700');
      });
      
      document.getElementById(`section-${sectionName}`).classList.add('active');
      event.target.closest('.sidebar-item').classList.add('active');
      event.target.closest('.sidebar-item').classList.remove('text-gray-700');
    }

    // Favorites functionality
    function toggleFavorite(providerId) {
      const icon = document.getElementById(`fav-${providerId}`);
      let favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
      
      if (favorites.includes(providerId)) {
        favorites = favorites.filter(id => id !== providerId);
        icon.classList.remove('text-red-500', 'fas');
        icon.classList.add('text-gray-400', 'far');
      } else {
        favorites.push(providerId);
        icon.classList.remove('text-gray-400', 'far');
        icon.classList.add('text-red-500', 'fas');
      }
      
      localStorage.setItem('favorites', JSON.stringify(favorites));
      updateFavoritesCount();
    }

    function updateFavoritesCount() {
      const favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
      document.getElementById('favorites-count').textContent = favorites.length;
    }

    // Load favorites on page load
    document.addEventListener('DOMContentLoaded', function() {
      updateFavoritesCount();
      const favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
      favorites.forEach(id => {
        const icon = document.getElementById(`fav-${id}`);
        if (icon) {
          icon.classList.remove('text-gray-400', 'far');
          icon.classList.add('text-red-500', 'fas');
        }
      });

    });

    // GSAP animations
    gsap.from('.stat-card', { y: 30, opacity: 0, duration: 0.6, stagger: 0.1, delay: 0.2 });
  </script>
</body>
</html>
