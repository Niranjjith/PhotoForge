<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Staff Applications - GraphyHub</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <nav class="flex justify-between items-center p-6 bg-white shadow-md fixed w-full z-50 top-0">
    <a href="/" class="text-2xl font-bold text-teal-600">
      <i class="fas fa-camera-retro"></i> GraphyHub
    </a>
    <div class="space-x-6">
      <a href="/providers/dashboard" class="hover:text-teal-600 transition">Dashboard</a>
      <form action="/auth/logout" method="POST" class="inline">
        <button type="submit" class="hover:text-teal-600 transition">Logout</button>
      </form>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-6 pt-24 pb-12">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-4xl font-bold text-gray-800">
        <i class="fas fa-users text-blue-600 mr-2"></i>Staff Applications
      </h1>
      <a href="/providers/dashboard" class="text-teal-600 hover:text-teal-700">
        <i class="fas fa-arrow-left mr-1"></i>Back to Dashboard
      </a>
    </div>

    <!-- Search and Filters -->
    <form method="GET" action="/staff/applications" class="bg-white rounded-xl shadow-lg p-6 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <input type="text" name="search" value="<%= search || '' %>" placeholder="Search by name, phone, skills..."
          class="p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
        <select name="status" class="p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
          <option value="">All Status</option>
          <option value="Pending" <%= status === 'Pending' ? 'selected' : '' %>>Pending</option>
          <option value="Contacted" <%= status === 'Contacted' ? 'selected' : '' %>>Contacted</option>
          <option value="Hired" <%= status === 'Hired' ? 'selected' : '' %>>Hired</option>
          <option value="Rejected" <%= status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
        </select>
        <label class="flex items-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50">
          <input type="checkbox" name="nearMe" value="true" <%= nearMe === 'true' ? 'checked' : '' %> class="mr-2">
          <span>Near Me (50km)</span>
        </label>
        <button type="submit" class="bg-blue-500 text-white font-bold py-3 rounded-lg hover:bg-blue-600 transition">
          <i class="fas fa-search mr-2"></i>Search
        </button>
      </div>
    </form>

    <!-- Staff List -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if (staffList && staffList.length > 0) { %>
        <% staffList.forEach(staff => { %>
          <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition">
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <h3 class="text-xl font-bold text-gray-800"><%= staff.name %></h3>
                  <p class="text-sm text-gray-600">
                    <i class="fas fa-phone mr-1"></i><%= staff.phone %>
                  </p>
                </div>
                <span class="px-3 py-1 rounded-full text-xs font-bold <%= 
                  staff.status === 'Hired' ? 'bg-green-100 text-green-800' : 
                  staff.status === 'Contacted' ? 'bg-blue-100 text-blue-800' : 
                  staff.status === 'Rejected' ? 'bg-red-100 text-red-800' : 
                  'bg-teal-100 text-teal-800' %>">
                  <%= staff.status %>
                </span>
              </div>

              <% if (staff.city) { %>
                <p class="text-sm text-gray-600 mb-2">
                  <i class="fas fa-map-marker-alt mr-1"></i><%= staff.city %><% if (staff.state) { %>, <%= staff.state %><% } %>
                </p>
              <% } %>

              <% if (staff.skills && staff.skills.length > 0) { %>
                <div class="mb-3">
                  <p class="text-sm font-medium text-gray-700 mb-1">Skills:</p>
                  <div class="flex flex-wrap gap-1">
                    <% staff.skills.slice(0, 3).forEach(skill => { %>
                      <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs"><%= skill %></span>
                    <% }) %>
                    <% if (staff.skills.length > 3) { %>
                      <span class="text-xs text-gray-500">+<%= staff.skills.length - 3 %> more</span>
                    <% } %>
                  </div>
                </div>
              <% } %>

              <div class="flex items-center justify-between text-sm text-gray-600 mb-4">
                <span><i class="fas fa-clock mr-1"></i><%= staff.availability %></span>
                <% if (staff.expectedSalary > 0) { %>
                  <span><i class="fas fa-rupee-sign mr-1"></i><%= staff.expectedSalary %>/month</span>
                <% } %>
              </div>

              <a href="/staff/applications/<%= staff._id %>" 
                 class="block w-full bg-blue-500 text-white text-center font-bold py-2 rounded-lg hover:bg-blue-600 transition">
                <i class="fas fa-eye mr-2"></i>View Details
              </a>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-span-3 text-center py-12">
          <i class="fas fa-users text-6xl text-gray-300 mb-4"></i>
          <p class="text-xl text-gray-500">No staff applications found.</p>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>

