<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Join as Staff - GraphyHub</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gradient-to-br from-blue-50 via-white to-blue-100 min-h-screen">
  <nav class="flex justify-between items-center p-6 bg-white shadow-md fixed w-full z-50 top-0">
    <a href="/" class="text-2xl font-bold text-teal-600">
      <i class="fas fa-camera-retro"></i> GraphyHub
    </a>
    <div class="space-x-6">
      <a href="/" class="hover:text-teal-600 transition">Home</a>
      <% if (user) { %>
        <form action="/auth/logout" method="POST" class="inline">
          <button type="submit" class="hover:text-teal-600 transition">Logout</button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="hover:text-teal-600 transition">Login</a>
      <% } %>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto px-6 pt-24 pb-12">
    <div class="text-center mb-8">
      <i class="fas fa-user-tie text-6xl text-blue-600 mb-4"></i>
      <h1 class="text-4xl font-bold mb-4 text-gray-800">Join Our Photography Team</h1>
      <p class="text-xl text-gray-600">Register your interest and let providers find you!</p>
    </div>

    <% if (typeof error !== 'undefined' && error.length > 0) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
        <%= error[0] %>
      </div>
    <% } %>
    <% if (typeof success !== 'undefined' && success.length > 0) { %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
        <%= success[0] %>
      </div>
    <% } %>

    <div class="bg-white rounded-2xl shadow-xl p-8">
      <form action="/staff/register" method="POST" class="space-y-6">
        <!-- Personal Information -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-gray-800">
            <i class="fas fa-user text-blue-600 mr-2"></i>Personal Information
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-gray-700 font-medium mb-2">Full Name *</label>
              <input type="text" name="name" required 
                     placeholder="Your full name"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
            </div>
            <div>
              <label class="block text-gray-700 font-medium mb-2">Phone Number *</label>
              <input type="tel" name="phone" required 
                     placeholder="+91 9876543210"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
            </div>
            <div>
              <label class="block text-gray-700 font-medium mb-2">Email (Optional)</label>
              <input type="email" name="email" 
                     placeholder="your@email.com"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
            </div>
            <div>
              <label class="block text-gray-700 font-medium mb-2">Expected Salary (₹/month)</label>
              <input type="number" name="expectedSalary" 
                     placeholder="e.g. 25000"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
            </div>
          </div>
        </div>

        <!-- Location -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-gray-800">
            <i class="fas fa-map-marker-alt text-blue-600 mr-2"></i>Location
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
            <div>
              <label class="block text-gray-700 font-medium mb-2">Address</label>
              <input type="text" name="address" 
                     placeholder="Street address"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
            </div>
            <div>
              <label class="block text-gray-700 font-medium mb-2">City</label>
              <input type="text" name="city" 
                     placeholder="City"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
            </div>
            <div>
              <label class="block text-gray-700 font-medium mb-2">State</label>
              <input type="text" name="state" 
                     placeholder="State"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-gray-700 font-medium mb-2">Latitude (for location tracking)</label>
              <input type="number" step="any" name="lat" id="lat-input"
                     placeholder="Auto-detect"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
            </div>
            <div>
              <label class="block text-gray-700 font-medium mb-2">Longitude (for location tracking)</label>
              <input type="number" step="any" name="lng" id="lng-input"
                     placeholder="Auto-detect"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
            </div>
          </div>
          <button type="button" onclick="getLocation()" class="bg-blue-500 text-white px-6 py-2 rounded-lg hover:bg-blue-600 transition">
            <i class="fas fa-map-marker-alt mr-2"></i>Use My Current Location
          </button>
        </div>

        <!-- Professional Details -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-gray-800">
            <i class="fas fa-briefcase text-blue-600 mr-2"></i>Professional Details
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-gray-700 font-medium mb-2">Experience</label>
              <textarea name="experience" rows="3" 
                        placeholder="e.g., 5 years in photography/video, events, etc."
                        class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none"></textarea>
            </div>
            <div>
              <label class="block text-gray-700 font-medium mb-2">Skills (comma separated)</label>
              <input type="text" name="skills" 
                     placeholder="e.g., Chef, Server, Event Manager, Bartender"
                     class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
              <p class="text-sm text-gray-500 mt-1">Separate multiple skills with commas</p>
            </div>
            <div>
              <label class="block text-gray-700 font-medium mb-2">Availability</label>
              <select name="availability" class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
                <option value="Event-based">Event-based (On-demand)</option>
                <option value="Part-time">Part-time</option>
                <option value="Full-time">Full-time</option>
                <option value="Weekend-only">Weekend-only</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Provider Selection (Optional) -->
        <div>
          <label class="block text-gray-700 font-medium mb-2">Interested in specific provider? (Optional)</label>
          <input type="text" name="interestedProviderId" 
                 placeholder="Provider ID (leave blank for all providers)"
                 class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
        </div>

        <button type="submit" class="w-full bg-blue-600 text-white font-bold py-4 rounded-lg hover:bg-blue-700 transition text-lg">
          <i class="fas fa-paper-plane mr-2"></i>Submit Application
        </button>
      </form>
    </div>

    <div class="mt-8 bg-blue-50 rounded-xl p-6 text-center">
      <h3 class="text-xl font-bold mb-2 text-gray-800">How It Works</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4 text-sm text-gray-700">
        <div>
          <i class="fas fa-user-plus text-3xl text-blue-600 mb-2"></i>
          <p><strong>1. Register</strong><br>Fill out your details and location</p>
        </div>
        <div>
          <i class="fas fa-search text-3xl text-blue-600 mb-2"></i>
          <p><strong>2. Get Discovered</strong><br>Providers can find you by location</p>
        </div>
        <div>
          <i class="fas fa-handshake text-3xl text-blue-600 mb-2"></i>
          <p><strong>3. Get Hired</strong><br>Providers contact you directly</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    function getLocation() {
      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(function(position) {
          document.getElementById('lat-input').value = position.coords.latitude.toFixed(6);
          document.getElementById('lng-input').value = position.coords.longitude.toFixed(6);
        });
      } else {
        alert("Geolocation is not supported by this browser.");
      }
    }
  </script>
</body>
</html>

