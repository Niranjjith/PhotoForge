<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= staff.name %> - Staff Application | GraphyHub</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <nav class="flex justify-between items-center p-6 bg-white shadow-md fixed w-full z-50 top-0">
    <a href="/" class="text-2xl font-bold text-teal-600">
      <i class="fas fa-camera-retro"></i> GraphyHub
    </a>
    <div class="space-x-6">
      <a href="/staff/applications" class="hover:text-teal-600 transition">
        <i class="fas fa-arrow-left mr-1"></i>Back to Applications
      </a>
      <form action="/auth/logout" method="POST" class="inline">
        <button type="submit" class="hover:text-teal-600 transition">Logout</button>
      </form>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto px-6 pt-24 pb-12">
    <div class="bg-white rounded-2xl shadow-xl p-8">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-800"><%= staff.name %></h1>
          <p class="text-gray-600 mt-1">
            <i class="fas fa-phone mr-1"></i><%= staff.phone %>
            <% if (staff.email) { %>
              | <i class="fas fa-envelope mr-1"></i><%= staff.email %>
            <% } %>
          </p>
        </div>
        <span class="px-4 py-2 rounded-lg font-bold <%= 
          staff.status === 'Hired' ? 'bg-green-100 text-green-800' : 
          staff.status === 'Contacted' ? 'bg-blue-100 text-blue-800' : 
          staff.status === 'Rejected' ? 'bg-red-100 text-red-800' : 
          'bg-teal-100 text-teal-800' %>">
          <%= staff.status %>
        </span>
      </div>

      <!-- Location Info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <h2 class="text-xl font-bold mb-3 text-gray-800">
            <i class="fas fa-map-marker-alt text-blue-600 mr-2"></i>Location
          </h2>
          <p class="text-gray-700"><%= staff.address || 'Address not provided' %></p>
          <p class="text-gray-700"><%= staff.city %><% if (staff.state) { %>, <%= staff.state %><% } %> <%= staff.zipCode %></p>
          <% if (distance !== null) { %>
            <p class="text-blue-600 font-bold mt-2">
              <i class="fas fa-ruler-horizontal mr-1"></i><%= distance %> km away from your location
            </p>
          <% } %>
          <% if (staff.lastLocationUpdate) { %>
            <p class="text-sm text-gray-500 mt-1">
              Last location update: <%= new Date(staff.lastLocationUpdate).toLocaleString() %>
            </p>
          <% } %>
        </div>
        <div>
          <h2 class="text-xl font-bold mb-3 text-gray-800">
            <i class="fas fa-briefcase text-blue-600 mr-2"></i>Professional Info
          </h2>
          <p class="text-gray-700 mb-2">
            <strong>Availability:</strong> <%= staff.availability %>
          </p>
          <% if (staff.expectedSalary > 0) { %>
            <p class="text-gray-700 mb-2">
              <strong>Expected Salary:</strong> ₹<%= staff.expectedSalary %>/month
            </p>
          <% } %>
          <% if (staff.experience) { %>
            <p class="text-gray-700">
              <strong>Experience:</strong> <%= staff.experience %>
            </p>
          <% } %>
        </div>
      </div>

      <!-- Skills -->
      <% if (staff.skills && staff.skills.length > 0) { %>
        <div class="mb-6">
          <h2 class="text-xl font-bold mb-3 text-gray-800">
            <i class="fas fa-tools text-blue-600 mr-2"></i>Skills
          </h2>
          <div class="flex flex-wrap gap-2">
            <% staff.skills.forEach(skill => { %>
              <span class="bg-blue-100 text-blue-800 px-4 py-2 rounded-full font-medium"><%= skill %></span>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Status Update Form -->
      <div class="border-t border-gray-200 pt-6">
        <h2 class="text-xl font-bold mb-4 text-gray-800">Update Status</h2>
        <form action="/staff/applications/<%= staff._id %>/status" method="POST" class="space-y-4">
          <div>
            <label class="block text-gray-700 font-medium mb-2">Status</label>
            <select name="status" class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none">
              <option value="Pending" <%= staff.status === 'Pending' ? 'selected' : '' %>>Pending</option>
              <option value="Contacted" <%= staff.status === 'Contacted' ? 'selected' : '' %>>Contacted</option>
              <option value="Hired" <%= staff.status === 'Hired' ? 'selected' : '' %>>Hired</option>
              <option value="Rejected" <%= staff.status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
            </select>
          </div>
          <div>
            <label class="block text-gray-700 font-medium mb-2">Notes</label>
            <textarea name="notes" rows="4" 
                      placeholder="Add notes about this staff member..."
                      class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none"><%= staff.notes || '' %></textarea>
          </div>
          <button type="submit" class="bg-blue-600 text-white font-bold px-6 py-3 rounded-lg hover:bg-blue-700 transition">
            <i class="fas fa-save mr-2"></i>Update Status
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="mt-6 bg-blue-50 rounded-lg p-4">
        <h3 class="font-bold text-gray-800 mb-2">Contact Information</h3>
        <p class="text-gray-700">
          <i class="fas fa-phone mr-2"></i><a href="tel:<%= staff.phone %>" class="text-blue-600 hover:underline"><%= staff.phone %></a>
        </p>
        <% if (staff.email) { %>
          <p class="text-gray-700">
            <i class="fas fa-envelope mr-2"></i><a href="mailto:<%= staff.email %>" class="text-blue-600 hover:underline"><%= staff.email %></a>
          </p>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>

