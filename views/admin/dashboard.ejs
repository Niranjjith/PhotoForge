<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - GraphyHub</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .admin-nav { height: 64px; }
    .admin-main { min-height: calc(100vh - 64px); padding-top: 64px; }
    .stat-card { transition: all 0.25s ease; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 12px 24px -8px rgba(0,0,0,0.1); }
    .admin-card { transition: all 0.25s ease; }
    .admin-card:hover { transform: translateY(-4px); box-shadow: 0 16px 32px -8px rgba(127,29,29,0.15); }
    .scroll-area { max-height: 320px; overflow-y: auto; scrollbar-width: thin; }
    .scroll-area::-webkit-scrollbar { width: 6px; }
    .scroll-area::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 3px; }
    .scroll-area::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    .scroll-area::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
  </style>
</head>
<body class="bg-slate-100 antialiased">
  <!-- Fixed Navbar -->
  <nav class="admin-nav fixed top-0 left-0 right-0 z-50 bg-white border-b border-slate-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-full flex justify-between items-center">
      <div class="flex items-center gap-4">
        <a href="/" class="text-xl font-bold text-red-800 hover:text-red-700 transition flex items-center gap-2">
          <i class="fas fa-camera-retro text-red-600"></i> GraphyHub
        </a>
        <span class="hidden sm:inline text-xs font-semibold text-red-700 bg-red-50 px-2.5 py-1 rounded-md">Admin</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="/admin/users" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Users</a>
        <a href="/admin/providers" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Creators</a>
        <a href="/admin/bookings" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Bookings</a>
        <a href="/" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">
          <i class="fas fa-external-link-alt mr-1"></i> Site
        </a>
        <form action="/auth/logout" method="POST" class="inline">
          <button type="submit" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">
            <i class="fas fa-sign-out-alt mr-1"></i> Logout
          </button>
        </form>
      </div>
    </div>
  </nav>

  <!-- Scrollable Main Content -->
  <main class="admin-main">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-800">Dashboard</h1>
        <p class="text-slate-500 mt-1">Platform overview and quick actions</p>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
        <div class="stat-card bg-white rounded-xl p-6 shadow-sm border border-slate-100">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-500">Total Users</p>
              <p class="text-3xl font-bold text-slate-800 mt-1"><%= stats.totalUsers %></p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center">
              <i class="fas fa-users text-blue-600 text-xl"></i>
            </div>
          </div>
        </div>
        <div class="stat-card bg-white rounded-xl p-6 shadow-sm border border-slate-100">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-500">Creators</p>
              <p class="text-3xl font-bold text-slate-800 mt-1"><%= stats.totalProviders %></p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center">
              <i class="fas fa-camera-retro text-emerald-600 text-xl"></i>
            </div>
          </div>
        </div>
        <div class="stat-card bg-white rounded-xl p-6 shadow-sm border border-slate-100">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-500">Total Bookings</p>
              <p class="text-3xl font-bold text-slate-800 mt-1"><%= stats.totalBookings %></p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-red-100 flex items-center justify-center">
              <i class="fas fa-calendar-check text-red-600 text-xl"></i>
            </div>
          </div>
        </div>
        <div class="stat-card bg-white rounded-xl p-6 shadow-sm border border-slate-100">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-500">Pending</p>
              <p class="text-3xl font-bold text-slate-800 mt-1"><%= stats.pendingBookings %></p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center">
              <i class="fas fa-clock text-amber-600 text-xl"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 mb-8">
        <a href="/admin/users" class="admin-card block bg-white rounded-xl p-6 shadow-sm border border-slate-100 hover:border-red-200">
          <div class="w-14 h-14 rounded-xl bg-blue-100 flex items-center justify-center mb-4">
            <i class="fas fa-users text-blue-600 text-2xl"></i>
          </div>
          <h3 class="font-semibold text-slate-800">Manage Users</h3>
          <p class="text-sm text-slate-500 mt-1">View and manage all accounts</p>
        </a>
        <a href="/admin/providers" class="admin-card block bg-white rounded-xl p-6 shadow-sm border border-slate-100 hover:border-red-200">
          <div class="w-14 h-14 rounded-xl bg-emerald-100 flex items-center justify-center mb-4">
            <i class="fas fa-camera-retro text-emerald-600 text-2xl"></i>
          </div>
          <h3 class="font-semibold text-slate-800">Manage Creators</h3>
          <p class="text-sm text-slate-500 mt-1">Verify and feature creators</p>
        </a>
        <a href="/admin/bookings" class="admin-card block bg-white rounded-xl p-6 shadow-sm border border-slate-100 hover:border-red-200">
          <div class="w-14 h-14 rounded-xl bg-red-100 flex items-center justify-center mb-4">
            <i class="fas fa-calendar-check text-red-600 text-2xl"></i>
          </div>
          <h3 class="font-semibold text-slate-800">Manage Bookings</h3>
          <p class="text-sm text-slate-500 mt-1">Oversee booking requests</p>
        </a>
      </div>

      <!-- Recent Activity -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
          <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
            <h2 class="font-semibold text-slate-800">Recent Bookings</h2>
            <a href="/admin/bookings" class="text-sm font-medium text-red-600 hover:text-red-700">View all</a>
          </div>
          <div class="scroll-area px-6 py-4">
            <% if (recentBookings && recentBookings.length > 0) { %>
              <div class="space-y-3">
                <% recentBookings.forEach(booking => { %>
                  <div class="flex items-center justify-between py-3 border-b border-slate-50 last:border-0">
                    <div class="flex items-center gap-3 min-w-0">
                      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-700 font-semibold text-sm flex-shrink-0">
                        <%= booking.customer.name.charAt(0).toUpperCase() %>
                      </div>
                      <div class="min-w-0">
                        <p class="font-medium text-slate-800 truncate"><%= booking.customer.name %></p>
                        <p class="text-xs text-slate-500 truncate"><%= booking.provider.businessName %></p>
                      </div>
                    </div>
                    <span class="text-xs px-2 py-1 rounded-full flex-shrink-0 <%= booking.status === 'Accepted' ? 'bg-green-100 text-green-700' : booking.status === 'Pending' ? 'bg-amber-100 text-amber-700' : 'bg-slate-100 text-slate-600' %>">
                      <%= booking.status %>
                    </span>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="py-12 text-center text-slate-400">
                <i class="fas fa-calendar-times text-4xl mb-3"></i>
                <p>No recent bookings</p>
              </div>
            <% } %>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
          <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
            <h2 class="font-semibold text-slate-800">Recent Creators</h2>
            <a href="/admin/providers" class="text-sm font-medium text-red-600 hover:text-red-700">View all</a>
          </div>
          <div class="scroll-area px-6 py-4">
            <% if (recentProviders && recentProviders.length > 0) { %>
              <div class="space-y-3">
                <% recentProviders.forEach(provider => { %>
                  <div class="flex items-center justify-between py-3 border-b border-slate-50 last:border-0">
                    <div class="flex items-center gap-3 min-w-0">
                      <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-700 font-semibold text-sm flex-shrink-0">
                        <%= provider.businessName.charAt(0).toUpperCase() %>
                      </div>
                      <div class="min-w-0">
                        <p class="font-medium text-slate-800 truncate"><%= provider.businessName %></p>
                        <p class="text-xs text-slate-500 truncate"><%= provider.owner.name %></p>
                      </div>
                    </div>
                    <% if (provider.isVerified) { %>
                      <span class="text-xs px-2 py-1 rounded-full bg-emerald-100 text-emerald-700 flex-shrink-0">Verified</span>
                    <% } else { %>
                      <span class="text-xs px-2 py-1 rounded-full bg-amber-100 text-amber-700 flex-shrink-0">Pending</span>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="py-12 text-center text-slate-400">
                <i class="fas fa-camera text-4xl mb-3"></i>
                <p>No recent creators</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
