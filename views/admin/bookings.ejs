<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Bookings - Admin | GraphyHub</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .admin-nav { height: 64px; }
    .admin-main { min-height: calc(100vh - 64px); padding-top: 64px; }
  </style>
</head>
<body class="bg-slate-100 antialiased">
  <nav class="admin-nav fixed top-0 left-0 right-0 z-50 bg-white border-b border-slate-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-full flex justify-between items-center">
      <div class="flex items-center gap-4">
        <a href="/admin" class="text-xl font-bold text-red-800 hover:text-red-700 transition flex items-center gap-2">
          <i class="fas fa-camera-retro text-red-600"></i> GraphyHub
        </a>
        <span class="hidden sm:inline text-xs font-semibold text-red-700 bg-red-50 px-2.5 py-1 rounded-md">Admin</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="/admin/users" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Users</a>
        <a href="/admin/providers" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Creators</a>
        <a href="/admin/bookings" class="text-red-600 font-medium text-sm">Bookings</a>
        <a href="/" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Site</a>
        <form action="/auth/logout" method="POST" class="inline">
          <button type="submit" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="admin-main">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-slate-800">Manage Bookings</h1>
          <p class="text-slate-500 text-sm mt-1">Oversee and update booking requests</p>
        </div>
        <a href="/admin" class="inline-flex items-center gap-2 text-sm font-medium text-red-600 hover:text-red-700">
          <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
      </div>

      <form method="GET" action="/admin/bookings" class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 sm:p-6 mb-6">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <input type="text" name="search" value="<%= search || '' %>" placeholder="Search by creator name..."
            class="px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 text-sm">
          <select name="status" class="px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-500 text-sm">
            <option value="">All Status</option>
            <option value="Pending" <%= status === 'Pending' ? 'selected' : '' %>>Pending</option>
            <option value="Accepted" <%= status === 'Accepted' ? 'selected' : '' %>>Accepted</option>
            <option value="Rejected" <%= status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
            <option value="Completed" <%= status === 'Completed' ? 'selected' : '' %>>Completed</option>
            <option value="Cancelled" <%= status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
          <button type="submit" class="px-4 py-2.5 bg-red-700 text-white rounded-lg hover:bg-red-800 font-medium text-sm">
            <i class="fas fa-search mr-2"></i>Search
          </button>
        </div>
      </form>

      <div class="space-y-4">
        <% if (bookings && bookings.length > 0) { %>
          <% bookings.forEach(booking => { %>
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 sm:p-6">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-slate-800"><%= booking.provider.businessName %></h3>
                  <p class="text-sm text-slate-600 mt-0.5">Customer: <%= booking.customer.name %> (<%= booking.customer.email %>)</p>
                </div>
                <form action="/admin/bookings/<%= booking._id %>/status" method="POST" class="flex flex-wrap items-center gap-2 flex-shrink-0">
                  <select name="status" class="px-3 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-500 text-sm">
                    <option value="Pending" <%= booking.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                    <option value="Accepted" <%= booking.status === 'Accepted' ? 'selected' : '' %>>Accepted</option>
                    <option value="Rejected" <%= booking.status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
                    <option value="Completed" <%= booking.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                    <option value="Cancelled" <%= booking.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                  </select>
                  <button type="submit" class="px-4 py-2 bg-red-700 text-white rounded-lg hover:bg-red-800 text-sm font-medium">
                    Update
                  </button>
                </form>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4 pt-4 border-t border-slate-100">
                <div>
                  <p class="text-xs text-slate-500">Date & Type</p>
                  <p class="text-sm text-slate-800"><%= new Date(booking.eventDate).toLocaleDateString() %></p>
                  <p class="text-sm text-slate-600"><%= booking.eventType %></p>
                </div>
                <div>
                  <p class="text-xs text-slate-500">Location</p>
                  <p class="text-sm text-slate-800"><%= booking.eventLocation && booking.eventLocation.address ? booking.eventLocation.address : 'N/A' %></p>
                  <p class="text-sm text-slate-600"><%= booking.eventLocation && booking.eventLocation.city ? booking.eventLocation.city : '' %></p>
                </div>
                <div>
                  <p class="text-xs text-slate-500">Amount & Created</p>
                  <p class="text-sm font-semibold text-slate-800">₹<%= booking.finalAmount %></p>
                  <p class="text-sm text-slate-600"><%= new Date(booking.createdAt).toLocaleDateString() %></p>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-16 text-center">
            <i class="fas fa-calendar-times text-5xl text-slate-300 mb-4"></i>
            <p class="text-slate-500">No bookings found</p>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
