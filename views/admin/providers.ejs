<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Creators - Admin | GraphyHub</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .admin-nav { height: 64px; }
    .admin-main { min-height: calc(100vh - 64px); padding-top: 64px; }
  </style>
</head>
<body class="bg-slate-100 antialiased">
  <nav class="admin-nav fixed top-0 left-0 right-0 z-50 bg-white border-b border-slate-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-full flex justify-between items-center">
      <div class="flex items-center gap-4">
        <a href="/admin" class="text-xl font-bold text-red-800 hover:text-red-700 transition flex items-center gap-2">
          <i class="fas fa-camera-retro text-red-600"></i> GraphyHub
        </a>
        <span class="hidden sm:inline text-xs font-semibold text-red-700 bg-red-50 px-2.5 py-1 rounded-md">Admin</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="/admin/users" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Users</a>
        <a href="/admin/providers" class="text-red-600 font-medium text-sm">Creators</a>
        <a href="/admin/bookings" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Bookings</a>
        <a href="/" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Site</a>
        <form action="/auth/logout" method="POST" class="inline">
          <button type="submit" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="admin-main">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-slate-800">Manage Creators</h1>
          <p class="text-slate-500 text-sm mt-1">Verify and feature photographers & video editors</p>
        </div>
        <a href="/admin" class="inline-flex items-center gap-2 text-sm font-medium text-red-600 hover:text-red-700">
          <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
      </div>

      <form method="GET" action="/admin/providers" class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 sm:p-6 mb-6">
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
          <input type="text" name="search" value="<%= search || '' %>" placeholder="Search name, city..."
            class="sm:col-span-1 px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 text-sm">
          <select name="verified" class="px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-500 text-sm">
            <option value="">All</option>
            <option value="true" <%= verified === 'true' ? 'selected' : '' %>>Verified</option>
            <option value="false" <%= verified === 'false' ? 'selected' : '' %>>Not Verified</option>
          </select>
          <select name="featured" class="px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-500 text-sm">
            <option value="">All</option>
            <option value="true" <%= featured === 'true' ? 'selected' : '' %>>Featured</option>
            <option value="false" <%= featured === 'false' ? 'selected' : '' %>>Not Featured</option>
          </select>
          <button type="submit" class="px-4 py-2.5 bg-red-700 text-white rounded-lg hover:bg-red-800 font-medium text-sm">
            <i class="fas fa-search mr-2"></i>Search
          </button>
        </div>
      </form>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 sm:gap-6">
        <% if (providers && providers.length > 0) { %>
          <% providers.forEach(provider => { %>
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition">
              <div class="relative h-40 overflow-hidden">
                <img src="<%= provider.coverImage || 'https://images.unsplash.com/photo-1542038784456-1ea8e935640e?auto=format&fit=crop&w=800&q=80' %>" 
                     alt="<%= provider.businessName %>" class="w-full h-full object-cover">
                <div class="absolute top-3 right-3 flex gap-2">
                  <% if (provider.isVerified) { %>
                    <span class="bg-emerald-500 text-white px-2 py-0.5 rounded text-xs font-medium">Verified</span>
                  <% } %>
                  <% if (provider.isFeatured) { %>
                    <span class="bg-red-700 text-white px-2 py-0.5 rounded text-xs font-medium">Featured</span>
                  <% } %>
                </div>
              </div>
              <div class="p-4 sm:p-5">
                <h3 class="font-semibold text-slate-800 truncate"><%= provider.businessName %></h3>
                <p class="text-sm text-slate-500 truncate mt-0.5"><%= provider.owner.name %></p>
                <p class="text-sm text-slate-500 flex items-center gap-1 mt-2">
                  <i class="fas fa-map-marker-alt text-slate-400 text-xs"></i>
                  <%= provider.city || provider.address || 'N/A' %>
                </p>
                <div class="flex items-center gap-3 mt-3 text-sm">
                  <span class="text-red-600 font-semibold">⭐ <%= provider.rating.toFixed(1) %></span>
                  <span class="text-slate-400"><%= provider.totalReviews || 0 %> reviews</span>
                </div>
                <div class="flex gap-2 mt-4">
                  <form action="/admin/providers/<%= provider._id %>/verify" method="POST" class="flex-1">
                    <button type="submit" class="w-full py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 text-xs font-medium transition">
                      <%= provider.isVerified ? 'Unverify' : 'Verify' %>
                    </button>
                  </form>
                  <form action="/admin/providers/<%= provider._id %>/feature" method="POST" class="flex-1">
                    <button type="submit" class="w-full py-2 bg-red-700 text-white rounded-lg hover:bg-red-800 text-xs font-medium transition">
                      <%= provider.isFeatured ? 'Unfeature' : 'Feature' %>
                    </button>
                  </form>
                  <form action="/admin/providers/<%= provider._id %>?_method=DELETE" method="POST">
                    <button type="submit" onclick="return confirm('Delete this creator?')" 
                      class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition">
                      <i class="fas fa-trash text-sm"></i>
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-span-full bg-white rounded-xl shadow-sm border border-slate-100 p-16 text-center">
            <i class="fas fa-camera-retro text-5xl text-slate-300 mb-4"></i>
            <p class="text-slate-500">No creators found</p>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
