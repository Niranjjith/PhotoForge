<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Users - Admin | GraphyHub</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .admin-nav { height: 64px; }
    .admin-main { min-height: calc(100vh - 64px); padding-top: 64px; }
    .table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .table-scroll::-webkit-scrollbar { height: 6px; }
    .table-scroll::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 3px; }
    .table-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
  </style>
</head>
<body class="bg-slate-100 antialiased">
  <nav class="admin-nav fixed top-0 left-0 right-0 z-50 bg-white border-b border-slate-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-full flex justify-between items-center">
      <div class="flex items-center gap-4">
        <a href="/admin" class="text-xl font-bold text-red-800 hover:text-red-700 transition flex items-center gap-2">
          <i class="fas fa-camera-retro text-red-600"></i> GraphyHub
        </a>
        <span class="hidden sm:inline text-xs font-semibold text-red-700 bg-red-50 px-2.5 py-1 rounded-md">Admin</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="/admin/users" class="text-red-600 font-medium text-sm">Users</a>
        <a href="/admin/providers" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Creators</a>
        <a href="/admin/bookings" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Bookings</a>
        <a href="/" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Site</a>
        <form action="/auth/logout" method="POST" class="inline">
          <button type="submit" class="text-slate-600 hover:text-red-700 text-sm font-medium transition">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="admin-main">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-slate-800">Manage Users</h1>
          <p class="text-slate-500 text-sm mt-1">View and manage all user accounts</p>
        </div>
        <a href="/admin" class="inline-flex items-center gap-2 text-sm font-medium text-red-600 hover:text-red-700">
          <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
      </div>

      <form method="GET" action="/admin/users" class="bg-white rounded-xl shadow-sm border border-slate-100 p-4 sm:p-6 mb-6">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <input type="text" name="search" value="<%= search || '' %>" placeholder="Search by name or email..."
            class="px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 text-sm">
          <select name="role" class="px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 text-sm">
            <option value="">All Roles</option>
            <option value="customer" <%= role === 'customer' ? 'selected' : '' %>>Customer</option>
            <option value="provider" <%= role === 'provider' ? 'selected' : '' %>>Provider</option>
            <option value="admin" <%= role === 'admin' ? 'selected' : '' %>>Admin</option>
          </select>
          <button type="submit" class="px-4 py-2.5 bg-red-700 text-white rounded-lg hover:bg-red-800 font-medium text-sm">
            <i class="fas fa-search mr-2"></i>Search
          </button>
        </div>
      </form>

      <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="table-scroll">
          <table class="w-full min-w-[640px]">
            <thead class="bg-slate-50 border-b border-slate-200">
              <tr>
                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Name</th>
                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Email</th>
                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Role</th>
                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Student</th>
                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Created</th>
                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% if (users && users.length > 0) { %>
                <% users.forEach(user => { %>
                  <tr class="hover:bg-slate-50 transition">
                    <td class="px-4 sm:px-6 py-4 text-sm font-medium text-slate-800"><%= user.name %></td>
                    <td class="px-4 sm:px-6 py-4 text-sm text-slate-600"><%= user.email %></td>
                    <td class="px-4 sm:px-6 py-4">
                      <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium <%= 
                        user.role === 'admin' ? 'bg-red-100 text-red-800' : 
                        user.role === 'provider' ? 'bg-emerald-100 text-emerald-800' : 
                        'bg-blue-100 text-blue-800' %>"><%= user.role %></span>
                    </td>
                    <td class="px-4 sm:px-6 py-4">
                      <% if (user.isStudent) { %>
                        <i class="fas fa-check text-emerald-500"></i>
                      <% } else { %>
                        <span class="text-slate-300">—</span>
                      <% } %>
                    </td>
                    <td class="px-4 sm:px-6 py-4 text-sm text-slate-500"><%= new Date(user.createdAt).toLocaleDateString() %></td>
                    <td class="px-4 sm:px-6 py-4">
                      <form action="/admin/users/<%= user._id %>?_method=DELETE" method="POST" class="inline">
                        <button type="submit" onclick="return confirm('Delete this user?')" 
                          class="text-red-500 hover:text-red-700 p-1.5 rounded hover:bg-red-50 transition">
                          <i class="fas fa-trash text-sm"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="px-4 sm:px-6 py-16 text-center text-slate-500">
                    <i class="fas fa-users text-4xl mb-3 text-slate-300"></i>
                    <p>No users found</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
